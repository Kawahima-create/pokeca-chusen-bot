# ローカル実行用。実際の値を入れて `.env` にコピーし、`source .env` してから実行。
# GitHub Actions では Settings > Secrets に同名で登録する（このファイルは使わない）。

export DISCORD_BOT_TOKEN="ここにBotトークン"

# タイトル別チャンネル（設定したタイトルだけ通知する。未設定はスキップ）
export DISCORD_CHANNEL_POKECA="ポケカ通知チャンネルのID"
export DISCORD_CHANNEL_ONEPIECE="ワンピ通知チャンネルのID"
export DISCORD_CHANNEL_YUGIOH="遊戯王通知チャンネルのID"
# 無料『撒き餌』チャンネル（公式大型抽選のみ流す）
export DISCORD_CHANNEL_FREE="無料版チャンネルのID"

# ワンピ/遊戯王の入荷Now系ページURL（任意。設定するとそのタイトルも収集）
export NYUKA_URL_ONEPIECE="https://nyuka-now.com/archives/XXXX"
export NYUKA_URL_YUGIOH="https://nyuka-now.com/archives/YYYY"

# 当落メール通知の宛先（運営専用プライベートチャンネル）。
# ★あなた個人の当落メールを検知するので、会員が見えるチャンネルには絶対しないこと。
export DISCORD_CHANNEL_MAIL="運営専用チャンネルのID"

# 後方互換: 上の DISCORD_CHANNEL_* / _MAIL を使わない場合のみ。pokeca 単一チャンネル扱い。
export DISCORD_CHANNEL_ID="通知先チャンネルのID（18桁前後の数字）"
